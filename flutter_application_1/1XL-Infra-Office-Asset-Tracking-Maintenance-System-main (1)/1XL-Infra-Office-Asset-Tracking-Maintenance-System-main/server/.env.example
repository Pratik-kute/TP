# ============================================================================
# 1XL Asset Tracker — Mobile API Server
# ============================================================================
# Copy to .env and fill in. The server will refuse to start if any required
# value is missing or obviously placeholder.

# ----- Server -----
PORT=4000
NODE_ENV=development                       # development | production
LOG_LEVEL=info                             # trace|debug|info|warn|error
CORS_ORIGINS=http://localhost:5173,https://asset.thebizzfly.com

# ----- Supabase (server-side, service role) -----
# Server uses the service role to bypass RLS — it must NEVER be exposed to a
# browser. The web app keeps using the anon key separately.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ----- JWT signing -----
# Min 32 chars. Generate with `openssl rand -base64 48`.
# Rotating this invalidates every issued access + refresh token.
JWT_SECRET=replace-me-with-a-long-random-secret-min-32-chars
JWT_ACCESS_TTL_SECONDS=1800                # 30 min — Section 2.2
JWT_REFRESH_TTL_SECONDS=2592000            # 30 days — Section 2.2

# ----- API key hashing -----
# bcrypt cost. 10 = ~10ms, 12 = ~150ms. 10 is fine for our throughput.
BCRYPT_COST=10

# ----- Idempotency -----
IDEMPOTENCY_TTL_HOURS=24                   # Section 6.4

# ----- Photo upload -----
PHOTO_BUCKET=asset-images                  # Existing Supabase Storage bucket
PHOTO_MAX_BYTES=10485760                   # 10 MB — Section 7.1
PHOTO_PRESIGNED_TTL_SECONDS=600            # 10 min — Section 7.5

# ----- Rate limits -----
LOGIN_RATE_LIMIT_PER_15MIN=20              # /auth/login per IP — Section 6.2
DEFAULT_RATE_LIMIT_PER_MINUTE=120          # Per API key — overridable per key
