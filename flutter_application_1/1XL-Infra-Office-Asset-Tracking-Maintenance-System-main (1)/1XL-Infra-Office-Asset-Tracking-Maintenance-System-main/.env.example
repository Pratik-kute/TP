# ===== Vite (browser) =====
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Mobile-API server (the new Express service in /server). The React admin page
# at /:org/api-keys talks to this for create/list/revoke/usage. Default points
# at the local dev server.
VITE_MOBILE_API_URL=http://localhost:4000

# URL the "Send Monthly Report Now" button calls. Defaults to the local
# `supabase functions serve` URL. Change to your hosted URL if you ever
# decide to deploy the function.
VITE_MONTHLY_REPORT_FN_URL=http://localhost:54321/functions/v1/monthly-asset-report

# ===== Gmail API (used for ALL transactional email) =====
# All notification / signup / assignment / monthly-report emails are sent
# directly through the Gmail API using a long-lived refresh token.
#
# ⚠️ Security note: VITE_-prefixed vars are bundled into the browser. That
# means VITE_GMAIL_CLIENT_SECRET and VITE_GMAIL_REFRESH_TOKEN are visible to
# every visitor. If that is unacceptable, move email sending to the Edge
# Function and drop the VITE_ prefix from these three names.
VITE_GMAIL_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
VITE_GMAIL_REFRESH_TOKEN=your-google-oauth-refresh-token
# Email address the messages are sent From. Must match the Gmail account
# that authorized the refresh token. Used for the From header only — Gmail
# always sends from the authenticated account anyway.
VITE_GMAIL_SENDER=bot@your-domain.com
# Optional friendly display name for the From header.
VITE_GMAIL_SENDER_NAME=1XL Asset Tracker

# ===== Supabase Edge Function (read by `supabase functions serve --env-file .env`) =====
# These do NOT need a VITE_ prefix because Vite ignores them and they are
# only loaded when running the function locally. The monthly-report function
# falls back to the VITE_GMAIL_* values above if the non-prefixed copies are
# not set, so local development works without duplicating the credentials.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
OPENAI_API_KEY=sk-...
# For deployed Edge Functions, set these via `supabase secrets set`:
#   GMAIL_CLIENT_ID=...
#   GMAIL_CLIENT_SECRET=...
#   GMAIL_REFRESH_TOKEN=...
#   GMAIL_SENDER=...
#   GMAIL_SENDER_NAME=...
